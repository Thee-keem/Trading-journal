generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id              String           @id @default(uuid())
  email           String           @unique
  password_hash   String
  created_at      DateTime         @default(now())
  trading_accounts TradingAccount[]
  trading_plans   TradingPlan[]
  playbooks       Playbook[]
  ai_insights     AiInsight[]
  alert_preference UserAlertPreference?
}

model TradingAccount {
  id               String   @id @default(uuid())
  user_id          String
  broker_name      String
  account_name     String
  account_type     String   // Demo, Live, Funded
  starting_balance Float
  currency         String   @default("USD")
  leverage         Int
  archived         Boolean  @default(false)
  created_at       DateTime @default(now())

  user             User           @relation(fields: [user_id], references: [id], onDelete: Cascade)
  trades           Trade[]
  trading_plans    TradingPlan[]
  ai_insights      AiInsight[]
}

model Trade {
  id           String   @id @default(uuid())
  user_id      String
  account_id   String
  pair         String
  session      String   // Sydney, Tokyo, London, New York
  direction    String   // Long, Short
  entry        Float
  exit         Float?
  stop_loss    Float?
  take_profit  Float?
  lot_size     Float
  contract_size Float?  @default(100000)
  exchange_rate Float?  @default(1.0)
  fees         Float?   @default(0)
  commission   Float?   @default(0)
  swap         Float?   @default(0)
  risk_percent Float?
  rr           Float?   // Reward:Risk ratio
  pnl          Float?
  result_percent Float?
  is_win       Boolean?
  result       String?  // Win, Loss, Break Even
  confirmations Json?
  emotion      String?
  screenshot_url String?
  notes        String?
  plan_violation Boolean @default(false)
  after_loss     Boolean @default(false)
  created_at   DateTime @default(now())

  account      TradingAccount @relation(fields: [account_id], references: [id], onDelete: Cascade)
}

model TradingPlan {
  id                  String   @id @default(uuid())
  user_id             String
  account_id          String?
  title               String
  risk_rules          Json
  daily_rules         Json
  session_rules       Json
  psychology_rules    Json
  max_daily_loss      Float?
  max_weekly_loss     Float?
  max_trades_per_day  Int?
  allowed_sessions    Json?
  created_at          DateTime @default(now())
  updated_at          DateTime @updatedAt

  user                User            @relation(fields: [user_id], references: [id], onDelete: Cascade)
  account             TradingAccount? @relation(fields: [account_id], references: [id], onDelete: Cascade)
}

model Playbook {
  id            String   @id @default(uuid())
  user_id       String
  name          String
  conditions    Json
  confirmations Json
  invalidations Json
  risk_model    Json?
  created_at    DateTime @default(now())

  user          User     @relation(fields: [user_id], references: [id], onDelete: Cascade)
}

model EconomicEvent {
  id             String   @id @default(uuid())
  event_name     String
  currency       String
  impact         String   // Low, Medium, High
  event_time_utc DateTime
  forecast       String?
  previous       String?
  actual         String?
  country        String?
  created_at     DateTime @default(now())
}

model UserAlertPreference {
  id                   String   @id @default(uuid())
  user_id              String   @unique
  monitored_currencies Json? // e.g., ["USD", "EUR", "GBP", "JPY", "XAU"]
  minimum_impact       String   @default("Medium") // Low, Medium, High
  alert_offsets        Json?    // Minutes: e.g., [60, 30, 15, 5]
  email_enabled        Boolean  @default(false)
  push_enabled         Boolean  @default(false)
  created_at           DateTime @default(now())
  updated_at           DateTime @updatedAt

  user User @relation(fields: [user_id], references: [id], onDelete: Cascade)
}

model AiInsight {
  id           String   @id @default(uuid())
  user_id      String
  account_id   String?
  category     String   // Strategy, Psychology, Risk, Performance
  content      String
  created_at   DateTime @default(now())

  user         User            @relation(fields: [user_id], references: [id], onDelete: Cascade)
  account      TradingAccount? @relation(fields: [account_id], references: [id], onDelete: Cascade)
}
